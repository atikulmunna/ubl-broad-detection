# AWS/Localstack config (use localhost when running outside docker)
AWS_ENDPOINT_URL=http://localhost:4566
AWS_DEFAULT_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# S3/SQS
S3_BUCKET=ubl-shop-audits
SQS_IMAGE_QUEUE_URL=http://localhost:4566/000000000000/ubl-image-processing-queue
SQS_RESULTS_QUEUE_URL=http://localhost:4566/000000000000/ubl-ai-results-queue

# Debug - save inference images
DEBUG_MODE=true
DEBUG_OUTPUT_DIR=debug_output

# Workers
NUM_INFERENCE_WORKERS=4
PYTHONUNBUFFERED=1
