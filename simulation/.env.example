# UBL Simulation Environment Variables

# =============================================================================
# AWS / LocalStack Configuration
# =============================================================================
AWS_ENDPOINT_URL=http://localstack:4566
AWS_DEFAULT_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# S3 Bucket
S3_BUCKET=ubl-shop-audits

# SQS Queue URLs
SQS_IMAGE_QUEUE_URL=http://localstack:4566/000000000000/ubl-image-processing-queue
SQS_RESULTS_QUEUE_URL=http://localstack:4566/000000000000/ubl-ai-results-queue

# =============================================================================
# Backend API Configuration
# =============================================================================
API_KEY=
# Leave empty to disable authentication
# Set to a secure value for production: API_KEY=your-secret-key-here

ALLOWED_ORIGINS=*
# Comma-separated list of allowed CORS origins
# Production example: ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

MAX_IMAGE_SIZE_MB=15
# Maximum image upload size in megabytes

# =============================================================================
# AI Server Configuration
# =============================================================================
NUM_INFERENCE_WORKERS=4
# Number of concurrent CUDA streams for parallel processing
# Adjust based on GPU memory:
# - 1 worker: ~2GB VRAM, ~30 img/s
# - 4 workers: ~6GB VRAM, ~100 img/s  (recommended)
# - 6 workers: ~8GB VRAM, ~150 img/s
# - 8 workers: ~10GB VRAM, ~200 img/s

# =============================================================================
# Client Configuration (for testing)
# =============================================================================
BACKEND_URL=http://localhost:8000
# Backend API URL for client uploads

IMAGES_DIR=./sample-images
# Directory containing sample images for testing
