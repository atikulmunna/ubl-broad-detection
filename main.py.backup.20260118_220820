        # Run detection for all products (UBL + Competitor) - DA_YOLO11X now has 243 classes
        sos_conf = SHARE_OF_SHELF_CONFIG.get('conf', SHARE_OF_SHELF_CONFIG.get('ubl_conf', 0.20))
        logger.debug(f"[Worker {worker_id}] [SOS] Running detection with conf={sos_conf}")
        results = model_manager.predict(
            'ubl',
            source=pil_image,
            worker_id=worker_id,
            conf=sos_conf,
            verbose=False
        )

        # Classify detections as UBL or Competitor using is_ubl config field
        ubl_products = defaultdict(int)
        competitor_products = defaultdict(int)
        model_result = results[0] if results else None
        
        # Diagnostic logging for model results
        if not model_result:
            logger.warning(f"[Worker {worker_id}] [SOS] ⚠ Model returned no results object")
        elif not model_result.boxes:
            logger.warning(f"[Worker {worker_id}] [SOS] ⚠ Model returned results but no boxes detected (conf={sos_conf})")
        else:
