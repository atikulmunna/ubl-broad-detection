            logger.info(f"[Worker {worker_id}] [SOS] Model detected {raw_detection_count} boxes with conf>={sos_conf}")

        if model_result and model_result.boxes:
            for box in model_result.boxes:
                cls_id = int(box.cls[0])
                class_name = model_result.names[cls_id]

                # Look up brand and category
                brand = extract_brand_from_product(class_name)
                category = get_sos_category(class_name) or "unknown"

                # Check is_ubl field in config
                norm_key = (brand, category)
                brand_entry = BRAND_NORMS.get(norm_key)

                if brand_entry and brand_entry.get('is_ubl') == 'yes':
                    ubl_products[class_name] += 1
                else:
                    competitor_products[class_name] += 1
            
            logger.debug(f"[Worker {worker_id}] [SOS] UBL products: {dict(ubl_products)}")
            logger.debug(f"[Worker {worker_id}] [SOS] Competitor products: {dict(competitor_products)}")

        # Calculate totals
        ubl_count = sum(ubl_products.values())
        competitor_count = sum(competitor_products.values())
        logger.info(f"[Worker {worker_id}] [SOS] ✓ Analysis complete: {ubl_count} UBL + {competitor_count} competitor products")

        # Calculate compliance (only for UBL products)
        compliance_score = 0.0
        product_accuracy = []

        if SOS_AVAILABLE and calculate_sos_compliance:
            compliance_score, product_accuracy = calculate_sos_compliance(dict(ubl_products))

        # Group ALL products (UBL + Competitor) by category
        category_breakdown = defaultdict(lambda: defaultdict(int))
        for class_name, count in ubl_products.items():
            cat = get_sos_category(class_name) or "unknown"
            category_breakdown[cat][class_name] = count
        for class_name, count in competitor_products.items():
            cat = get_sos_category(class_name) or "unknown"
            category_breakdown[cat][class_name] = count

        return {
            "model_version": "DA_YOLO11X (243 classes - UBL + Competitor)",
            "confidence": sos_conf,
            "total_products": ubl_count + competitor_count,
            "unique_products": len(ubl_products) + len(competitor_products),
            "ubl_product_breakdown": dict(ubl_products),
            "competitor_product_breakdown": dict(competitor_products),
            "category_breakdown": {k: dict(v) for k, v in category_breakdown.items()},
            "competitor_count": competitor_count,
            "compliance_score": compliance_score,
            "product_accuracy": product_accuracy,
            "summary": f"Detected {ubl_count} UBL + {competitor_count} competitor products"
        }

    except Exception as e:
        logger.error(f"Error in analyze_share_of_shelf: {e}", exc_info=True)
        return {
            "error": str(e),
            "summary": "Error processing Share of Shelf"
        }


async def analyze_fixed_shelf(image_data: bytes, worker_id: int = 0, shelf_type: str = None, selected_category: str = "all") -> dict:
    """Analyze Fixed Shelf (QPDS) - FULL IMPLEMENTATION with all features"""
    logger.info(f"[Worker {worker_id}] [QPDS] Starting Fixed Shelf analysis (shelf_type={shelf_type}, category={selected_category})")
    try:
        pil_image = Image.open(BytesIO(image_data)).convert("RGB")
        image = np.array(pil_image)
        img_height, img_width = image.shape[:2]
        logger.info(f"[Worker {worker_id}] [QPDS] Image dimensions: {img_width}x{img_height}")
        logger.debug(f"[Worker {worker_id}] [QPDS] Image size: {len(image_data)} bytes")

        # Get config
        st_conf = FIXED_SHELF_CONFIG.get('shelftalker_conf', 0.15)
        ubl_conf = FIXED_SHELF_CONFIG.get('ubl_conf', 0.25)
        exclusivity_conf = FIXED_SHELF_CONFIG.get('exclusivity_conf', 0.35)
        expand_margin = FIXED_SHELF_CONFIG.get('expand_margin', 0.05)
        logger.debug(f"[Worker {worker_id}] [QPDS] Config: st_conf={st_conf}, ubl_conf={ubl_conf}, exclusivity_conf={exclusivity_conf}")

        # Step 1: Detect shelftalkers and create combined ROI
        combined_roi, shelftalkers = _detect_shelftalker_roi(worker_id, pil_image, st_conf, expand_margin, shelf_type)
        logger.info(f"[QPDS] Shelftalkers detected: {len(shelftalkers)}")
        if shelftalkers:
            for st in shelftalkers:
                logger.info(f"  - {st['position']}: {st['class_name']} (conf: {st['confidence']:.2f})")

        # Step 2: Validate ROI quality
        roi_quality = _validate_roi_quality(shelftalkers, combined_roi, img_width, img_height, shelf_type)
        logger.info(f"[QPDS] ROI Quality: use_roi={roi_quality['use_roi']}, reason='{roi_quality['reason']}'")
        logger.info(f"[QPDS] ROI Details: detected={roi_quality['detected_count']}/{roi_quality['expected_count']}, area_ratio={roi_quality['roi_area_ratio']:.2%}")

        # Preserve the original ROI for exclusivity check
        exclusivity_roi = combined_roi
        detections = []
        method = "full_image"

        # Step 3: Decide whether to use ROI or full image
        if roi_quality['use_roi']:
            logger.info(f"[Worker {worker_id}] [QPDS] Using ROI-based detection: {roi_quality['reason']}")
            detections = _detect_products_in_roi(worker_id, pil_image, combined_roi, ubl_conf, selected_category)
            method = f"roi ({roi_quality['reason']})"
        else:
            logger.warning(f"[Worker {worker_id}] [QPDS] Using full-image detection: {roi_quality['reason']}")
            detections = _detect_products_full_image(worker_id, pil_image, ubl_conf, selected_category)
            method = f"full_image ({roi_quality['reason']})"

        logger.info(f"[Worker {worker_id}] [QPDS] Product detection complete: {len(detections)} products found")
        if len(detections) == 0:
            logger.warning(f"[Worker {worker_id}] [QPDS] ⚠ NO PRODUCTS DETECTED (conf={ubl_conf}, method={method})")
        # Step 4: Check exclusivity
        # Check exclusivity on ROI if quality is sufficient, otherwise check full image
        if exclusivity_roi is not None and roi_quality['use_roi']:
            exclusivity_data = _check_exclusivity(worker_id, pil_image, exclusivity_roi, exclusivity_conf)
        else:
            # When ROI quality is poor or no shelftalkers detected, check full image
            exclusivity_data = _check_exclusivity(worker_id, pil_image, None, exclusivity_conf)

        exclusivity_status = "yes" if exclusivity_data["is_exclusive"] else "no"
        non_ubl_count = exclusivity_data["non_ubl_count"]
        non_ubl_products = exclusivity_data["non_ubl_products"]

        # Step 5: Apply size variants
        size_summary = {}
        if SIZE_VARIANT_AVAILABLE and detections and assign_size_variants_simple:
            detections = assign_size_variants_simple(detections)
            size_summary = get_size_summary(detections)

        # Build product breakdown
        breakdown = defaultdict(int)
        for det in detections:
            breakdown[det['class_name']] += 1

        # Log detected products
        logger.info(f"[QPDS] Shelf Type: {shelf_type}")
        logger.info(f"[QPDS] Total products detected: {len(detections)}")
        logger.info(f"[QPDS] Product breakdown: {dict(breakdown)}")

        # Step 6: Calculate variant compliance if QPDS is available and shelf_type is provided
        variant_compliance = 0.0
        product_accuracy = []
        planogram_adherence = True
        shelftalker_adherence = True

        if QPDS_AVAILABLE and shelf_type:
            # For compliance, use size-aware product breakdown
            if size_summary:
                size_aware_breakdown = {}
                for product_name, sizes in size_summary.items():
                    total_count = sum(sizes.values())
                    size_aware_breakdown[product_name] = total_count
                variant_compliance, product_accuracy = calculate_compliance(shelf_type, size_aware_breakdown)
            else:
                variant_compliance, product_accuracy = calculate_compliance(shelf_type, dict(breakdown))

            # Check planogram adherence (product order left-to-right)
            detection_list = []
            for det in detections:
                detection_list.append({
                    'product_name': det['class_name'],
                    'bbox_xyxy': det['bbox_xyxy']
                })
            planogram_adherence = check_planogram_adherence(shelf_type, detection_list)

            # Check shelftalker adherence (minimum shelftalker count)
            shelftalker_adherence = check_shelftalker_adherence(shelf_type, len(shelftalkers))

            # Log planogram comparison
            logger.info(f"[QPDS] Planogram comparison for {shelf_type}:")
            for item in product_accuracy:
                logger.info(f"  - {item['name']}: planned={item['planned']}, visible={item['visible']}, accuracy={item['accuracy']}%")
            logger.info(f"[QPDS] Variant compliance: {variant_compliance}%")
            logger.info(f"[QPDS] Planogram adherence (order): {'Pass' if planogram_adherence else 'Fail'}")
            logger.info(f"[QPDS] Shelftalker adherence: {'Pass' if shelftalker_adherence else 'Fail'} ({len(shelftalkers)} detected)")

        # Format products array with correct field names
        products_formatted = []
        total_planned = 0
        total_visible = 0

        for item in product_accuracy:
            products_formatted.append({
                "sku_name": item["name"],
                "planned_qty": item["planned"],
                "visible_qty": item["visible"],
                "accuracy": item["accuracy"]
            })
            total_planned += item["planned"]
            total_visible += item["visible"]

        # Calculate overall compliance as (total_visible/total_planned)*100, capped at 100%
        overall_compliance = min((total_visible / total_planned * 100) if total_planned > 0 else 0, 100.0)

        # Log final results
        logger.info(f"[QPDS] Final Results:")
        logger.info(f"  Overall Compliance: {round(overall_compliance, 2)}%")
        logger.info(f"  Total Planned: {total_planned}, Total Visible: {total_visible}")
        logger.info(f"  Exclusivity: {exclusivity_status} (non-UBL: {non_ubl_count}, products: {non_ubl_products})")

        return {
            "model_version": "QPDS + Shelftalker + Exclusivity",
            "shelf_type": shelf_type or "Unknown",
            "status": "completed",

            # API output fields (matching ai_summary.json)
            "overall_compliance": round(overall_compliance, 2),
            "planogram_adherence": "Yes" if planogram_adherence else "No",
            "exclusively": "Yes" if exclusivity_status == "yes" else ("No" if exclusivity_status == "no" else "NA"),
            "variant_compliance": variant_compliance,
            "shelf_talker_present": "Yes" if len(shelftalkers) > 0 else "No",
            "shelf_talker_orientation_correct": "Yes" if shelftalker_adherence else "No",

            "products": products_formatted,
            "totals": {
                "total_planned": total_planned,
                "total_visible": total_visible
            },

            # Non-redundant metadata
            "no_of_shelftalker": len(shelftalkers),
            "shelftalkers_detected": shelftalkers,
            "total_products": len(detections),
            "product_breakdown": dict(breakdown),
            "selected_category": selected_category,
            "size_summary": size_summary,
            "method": method,
            "non_ubl_count": non_ubl_count,
            "non_ubl_products": non_ubl_products,

            "summary": f"Fixed Shelf: {len(detections)} products, {round(overall_compliance, 2)}% compliance, " +
                      f"Planogram: {'Pass' if planogram_adherence else 'Fail'}, " +
                      f"Shelftalker: {'Pass' if shelftalker_adherence else 'Fail'}, " +
                      f"Exclusivity: {exclusivity_status}"
        }
        logger.info(f"[Worker {worker_id}] [QPDS] ✓ Analysis complete: {len(detections)} products, {round(overall_compliance, 2)}% compliance")
        return result

    except Exception as e:
        logger.error(f"[Worker {worker_id}] [QPDS] ❌ Error in analyze_fixed_shelf: {e}", exc_info=True)
        return {
            "error": str(e),
            "summary": "Error processing Fixed Shelf"
        }


